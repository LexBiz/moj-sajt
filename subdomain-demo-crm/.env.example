PORT=3099
NODE_ENV=production

# Database
CRM_DATABASE_URL=
# Optional fallback alias
DATABASE_URL=

# Auth
CRM_JWT_SECRET=
CRM_REQUIRE_AUTH=true
CRM_ADMIN_EMAIL=admin@company.com
CRM_ADMIN_PASSWORD=

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v22.0
WHATSAPP_TARGET_NUMBER=+380960494917
WHATSAPP_TEMPLATE_NAME=new_lead_notification_v1
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_EXTRA_TARGET_NUMBERS=

# Email — Resend (outbound + inbound webhook)
RESEND_API_KEY=
RESEND_FROM=info@temoweb.eu
RESEND_INBOUND_DOMAIN=crm-reply.demo.temoweb.eu
RESEND_INBOUND_SECRET=
CLIENT_FORM_URL=https://demo.temoweb.eu/client-form.html
BRIEF_FORM_TO=info@temoweb.eu

# IMAP polling — Zoho Mail (reads inbox and links emails from known clients to CRM jobs)
# Get app password: Zoho Mail → Settings → Security → App Passwords
ZOHO_IMAP_USER=info@temoweb.eu
ZOHO_IMAP_PASS=
ZOHO_IMAP_HOST=imap.zoho.eu
ZOHO_IMAP_PORT=993
ZOHO_IMAP_MAILBOX=INBOX
# How often to check inbox in milliseconds (default: 120000 = 2 minutes)
IMAP_POLL_INTERVAL_MS=120000

# Fakturoid
FAKTUROID_ACCOUNT_SLUG=
FAKTUROID_API_TOKEN=
FAKTUROID_USER_AGENT=TemoWebCRM (info@temoweb.eu)

# OpenAI (AI extraction for commercial cases)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Offer documents (Excel/PDF)
# Folder with original styled templates (.xlsx)
CRM_OFFER_TEMPLATES_DIR=/var/www/mujsajt/subdomain-demo-crm/templates/offers
# Public base URL used in generated file links
CRM_PUBLIC_BASE_URL=https://demo.temoweb.eu
